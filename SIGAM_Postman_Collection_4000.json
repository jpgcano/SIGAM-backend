{
  "info": {
    "name": "SIGAM - J-AXON API",
    "description": "Colección completa de endpoints para el sistema SIGAM. Base URL: http://localhost:4000/api\n\nFlujo recomendado:\n1. POST /auth/login → copiar token\n2. Usar token en Authorization: Bearer <token>",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4000/api" },
    { "key": "token", "value": "PEGAR_TOKEN_AQUI" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@sigam.com\",\n  \"password\": \"Admin1234\"\n}"
            }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Analista\",\n  \"email\": \"analista@sigam.com\",\n  \"password\": \"Password1\",\n  \"rol\": \"Analista\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "📍 Ubicaciones",
      "item": [
        {
          "name": "GET Todas las ubicaciones",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/ubicaciones"
          }
        },
        {
          "name": "GET Ubicacion por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/ubicaciones/1"
          }
        },
        {
          "name": "POST Crear Ubicacion",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/ubicaciones",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sede\": \"Sede Principal Riwi\",\n  \"piso\": \"Piso 2\",\n  \"sala\": \"Sala de Desarrollo\"\n}"
            }
          }
        },
        {
          "name": "PUT Actualizar Ubicacion",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/ubicaciones/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sala\": \"Sala de QA\"\n}"
            }
          }
        },
        {
          "name": "DELETE Eliminar Ubicacion",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/ubicaciones/1"
          }
        }
      ]
    },
