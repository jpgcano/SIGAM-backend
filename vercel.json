{
  "version": 2,
  "installCommand": "corepack enable && corepack prepare pnpm@10.31.0 --activate && pnpm install",
  "builds": [
    {
      "src": "src/app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/app.js"
    }
  ],
  "crons": [
    { "path": "/api/cron/ia/tickets/reprocess", "schedule": "30 1 * * *" },
    { "path": "/api/cron/ia/repuestos/sugerencias", "schedule": "0 2 * * *" },
    { "path": "/api/cron/ia/activos/baja-sugerida", "schedule": "0 3 * * 1" },
    { "path": "/api/cron/ia/activos/obsolescencia", "schedule": "30 3 * * 0" },
    { "path": "/api/cron/ia/mantenimientos/preventivos", "schedule": "0 4 * * *" }
  ]
}
