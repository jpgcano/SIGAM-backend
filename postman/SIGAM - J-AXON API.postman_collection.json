                  "const data = pm.response.json();",
                  "const before = Number(pm.collectionVariables.get('stock_before'));",
                  "const used = Number(pm.collectionVariables.get('cantidad_usada'));",
                  "if (!Number.isNaN(before) && !Number.isNaN(used)) {",
                  "  pm.test('Stock descontado', function () {",
                  "    pm.expect(data.stock).to.eql(before - used);",
